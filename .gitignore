logs/
*.log
interrupt_debug.log
.hermes_history
.update_check

# --- Personal / chat state ---
sessions/
memories/

# --- Local locks ---
auth.lock

# --- SQLite session store (local runtime) ---
state.db
state.db-shm
state.db-wal

# --- Gateway / auth runtime ---
auth.json
gateway.lock
gateway.pid
gateway_state.json
kanban.db
.restart_last_processed.json
channel_directory.json
processes.json
